# Supabase — get from: supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Fix #3: Service role key — needed for admin operations that bypass RLS
# Get from: supabase.com → Settings → API → service_role (secret)
# WARNING: Never expose this on a public-facing API or commit to git
VITE_SUPABASE_SERVICE_KEY=your-service-role-key-here

# Resend — get from: resend.com → API Keys
VITE_RESEND_API_KEY=re_your_resend_api_key_here

# OneSignal — get from: onesignal.com → App → Settings → Keys & IDs
VITE_ONESIGNAL_APP_ID=your-onesignal-app-id-here
